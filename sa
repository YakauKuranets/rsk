<!DOCTYPE html>
<html>
<head>
	<title></title>
	<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
	<meta http-equiv="X-UA-Compatible" content="IE=edge" >
	<meta http-equiv="Pragma" content="no-cache" />
	<meta http-equiv="Cache-Control" content="no-cache, must-revalidate" />
	<meta http-equiv="Expires" content="0" />
	<script>
		document.write("<link type='text/css' href='../ui/css/ui.css?version=" + new Date().getTime() + "' rel='stylesheet' />");
	</script>
	<base target="_self" />
</head>
<body class="download-body">
	<div class="layout-north" id="header" ng-controller="headerController">
		<div class="header" ng-include="'common/header.asp'" onload="headerLoaded()"></div>
	</div>
	<div class="download layout-center" ng-controller="downloadController">
		<div class="layout-north-inner">
			<span class="download-type download-type-select" ng-click="changeDownType($event,0)" ng-bind="oLan.downloadByFile"></span>
			<span class="download-type" ng-if="fileType === 'record' && bSptDownLoadByTime" ng-click="changeDownType($event,1)" ng-bind="oLan.downloadbyDate"></span>
		</div>
		<div class="layout-west-inner">
			<div class="header"><label ng-bind="oLan.searchConditions"></label></div>
			<div class="west-content">
				<div ng-if="!bSupportCloudPic || fileType === 'record'" ng-show="iChannelNum > 1">
					<div class="file-type" ng-bind="oLan.camera"></div>
					<div channel analog="oAnalog" digital="oDigital" analog-num="iAnalogChannelNum" channel-id="channelInfo.iChannelId" lan="oLan"></div>
				</div>
				<div ng-if="bSupportCloudPic && fileType !== 'record'">
					<div class="file-type">ID</div>
					<div><input type="text" class="text" ng-model="$parent.cameraID"></div>
				</div>
				<div ng-show="bDownLoadByFile" ng-if="fileType === 'record'">
					<div class="file-type"><label ng-bind="oLan.fileType"></label></div>
					<div><select class="select" ng-model="params.recordFileType" ng-options="recordFileType.value as recordFileType.name for recordFileType in recordFileTypes" ie-select-fix></select></div>
				</div>
				<div ng-if="fileType === 'record' && bSupportSubStreamPlay">
					<div class="file-type"><label ng-bind="oLan.streamType"></label></div>
					<div>
						<select class="select" ng-model="params.streamType" ie-select-fix>
							<option value="1" ng-bind="oLan.mainStream"></option>
							<option value="2" ng-bind="oLan.subStream"></option>
						</select>
					</div>
				</div>
				<div ng-if="fileType !== 'record' && !bSupportCloudPic">
					<div class="file-type"><label ng-bind="oLan.fileType"></label></div>
					<div><select class="select" ng-model="params.captureFileType" ng-options="captureFileType.value as captureFileType.name for captureFileType in captureFileTypes" ie-select-fix></select></div>
				</div>
				<div ng-show="params.captureFileType === 'vehicleDetection' && !bSupportCloudPic">
					<div ng-show="aCountryList.length === 0" class="file-type"><label ng-bind="oLan.provinceAbbreviation"></label></div>
					<div ng-show="aCountryList.length === 0"><select class="select" ng-model="province" ng-options="province.value as province.name for province in provinces"></select></div>
					<div ng-show="aCountryList.length > 0" class="file-type"><label ng-bind="oLan.areaCountry"></label></div>
					<div ng-show="aCountryList.length > 0"><select class="select" ng-model="country" ng-options="oCountry.value as oCountry.name for oCountry in aCountryList"></select></div>
					<div class="file-type"><label ng-bind="oLan.plateNumber"></label></div>
					<div><input type="text" class="text" ng-model="plate"></div>
				</div>
				<div ng-show="bDownLoadByFile" class="search-time"><label ng-bind="oLan.startTime"></label></div>
				<div ng-show="bDownLoadByFile"><input type="text" class="Wdate" dp-model="oSearchTime.startTime" date></div>
				<div ng-show="bDownLoadByFile" class="search-time"><label ng-bind="oLan.endTime"></label></div>
				<div ng-show="bDownLoadByFile"><input type="text" class="Wdate" dp-model="oSearchTime.endTime" date></div>
				<div ng-show="bDownLoadByFile">
					<button type="button" class="btn search-btn" ng-click="searchFile()" ng-disabled="!bSupportSearch || bDownloading">
						<span class="img">&nbsp;</span>
						<span ng-bind="oLan.search"></span>
					</button>
				</div>

			</div>
		</div>
		<div  ng-show="!bDownloadByTime"  class="layout-center-inner">
			<div class="layout-north-inner-inner">
				<div class="header">
					<label ng-bind="oLan.fileList"></label>
					<div class="right">
						<button type="button" class="btn" ng-disabled="!bNotPlugin && (bDownloading || bDateDownloading)" ng-click="startDownload()">
							<span class="download-btn start-download-btn">&nbsp;</span>
							<span ng-bind="oLan.download"></span>
						</button>
						<button type="button" class="btn" ng-show="!bNotPlugin" ng-disabled="!bDownloading || bDateDownloading" ng-click="stopDownload()">
							<span class="download-btn stop-download-btn">&nbsp;</span>
							<span ng-bind="oLan.stopDownload"></span>
						</button>
					</div>
				</div>
			</div>
			<div class="layout-center-inner-inner">
				<div id="table" class="inner-body"></div>
			</div>
		</div>
		<div class="download-by-time" ng-show="fileType === 'record' && bDownloadByTime">
		    <div class="header">
		        <label ng-bind="oLan.timeSlotList"></label>
            	<div class="right_btn">
            	    <button type="button" class="btn" ng-disabled="bDownloading || bFileDownloading" ng-click="startDownload()">
            		    <span class="download-btn start-download-btn">&nbsp;</span>
            			<span ng-bind="oLan.download"></span>
            		</button>
            		<button type="button" class="btn" ng-disabled="!bDownloading || bFileDownloading" ng-click="stopDownload()">
            		    <span class="download-btn stop-download-btn">&nbsp;</span>
            			<span ng-bind="oLan.stopDownload"></span>
            		</button>
            	</div>
            </div>
            <div class="byTimeBody">
                <div class="inner-body">
                    <div class="table">
                        <div class="table-header">
                            <span class="table-cell spanPs4">
                                <!--<input type="checkbox" class="checkbox">-->
                            </span>
                            <span class="table-cell duration" ng-bind="oLan.timeSlot"></span>
                            <span class="table-cell time-section" ng-bind="oLan.startTime"></span>
                            <span class="table-cell time-section" ng-bind="oLan.endTime"></span>
                            <span class="table-cell progress" ng-bind="oLan.downloadProgress"></span>
                            <span class="table-cell spanPs4"></span>
                        </div>
                        <div class="table-body" id="downloadTimeBody">
                            <div class="table-row table-even">
                                <span class="table-cell spanPs4">
                                    <input type="checkbox" class="checkbox" ng-disabled="bDownloading || bFileDownloading">
                                </span>
                                <span class="table-cell duration">1</span>
                                <span class="table-cell time-section"><input type="text" class="Wdate" dp-model="oDateSlotTime.startTime1" dpDisabled="bDownloading || bFileDownloading" date></span>
                                <span class="table-cell time-section"><input type="text" class="Wdate" dp-model="oDateSlotTime.endTime1" dpDisabled="bDownloading || bFileDownloading" date></span>
                                <span class="table-cell progress"></span>
                            </div>
                            <div class="table-row table-odd">
                                <span class="table-cell spanPs4">
                                    <input type="checkbox" class="checkbox"ng-disabled="bDownloading || bFileDownloading">
                                </span>
                                <span class="table-cell duration">2</span>
                                <span class="table-cell time-section"><input type="text" class="Wdate" dp-model="oDateSlotTime.startTime2" dpDisabled="bDownloading || bFileDownloading" date></span>
                                <span class="table-cell time-section"><input type="text" class="Wdate" dp-model="oDateSlotTime.endTime2" dpDisabled="bDownloading || bFileDownloading" date></span>
                                <span class="table-cell progress"></span>
                            </div>
                            <div class="table-row table-even">
                                <span class="table-cell spanPs4">
                                    <input type="checkbox" class="checkbox"ng-disabled="bDownloading || bFileDownloading">
                                </span>
                                <span class="table-cell duration">3</span>
                                <span class="table-cell time-section"><input type="text" class="Wdate" dp-model="oDateSlotTime.startTime3" dpDisabled="bDownloading || bFileDownloading" date></span>
                                <span class="table-cell time-section"><input type="text" class="Wdate" dp-model="oDateSlotTime.endTime3" dpDisabled="bDownloading || bFileDownloading" date></span>
                                <span class="table-cell progress"></span>
                            </div>
                            <div class="table-row table-odd">
                                <span class="table-cell spanPs4">
                                    <input type="checkbox" class="checkbox"ng-disabled="bDownloading || bFileDownloading">
                                </span>
                                <span class="table-cell duration">4</span>
                                <span class="table-cell time-section"><input type="text" class="Wdate" dp-model="oDateSlotTime.startTime4" dpDisabled="bDownloading || bFileDownloading" date></span>
                                <span class="table-cell time-section"><input type="text" class="Wdate" dp-model="oDateSlotTime.endTime4" dpDisabled="bDownloading || bFileDownloading" date></span>
                                <span class="table-cell progress"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
		</div>
		<div id="main_plugin" class="no-window"></div>
	</div>
	<div class="layout-south">
		<div class="footer" id="footer"></div>
	</div>
</body>
<script id="seajsnode" src="../script/lib/seajs/seajs/sea.min.js"></script>
