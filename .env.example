# Hyperion Environment Variables
# Скопируйте этот файл в .env и заполните значения

# Shodan API
VITE_SHODAN_API_KEY=

# Дефолтные значения для UI (опционально)
VITE_DEFAULT_FUZZ_LOGIN=admin
VITE_DEFAULT_FUZZ_PATH=
VITE_DEFAULT_SPIDER_TARGET=
VITE_DEFAULT_SERVER_ALIAS=server1

# Мастер-пароль хранилища Hyperion Vault (ОБЯЗАТЕЛЬНО изменить!)
# Минимум 8 символов. Используется для шифрования targets_vault.
# Если не задан — Vault заблокирован, save_target вернёт ошибку.
# После изменения пароля старые данные станут недоступны.
HYPERION_VAULT_PASSPHRASE=your-strong-passphrase-here
