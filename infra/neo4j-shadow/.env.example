# Neo4j shadow-mode bootstrap configuration (Phase 32.1)
# Скопируйте в .env и заполните вручную реальными данными своей среды.
# Этот файл не является рабочим секретом и не должен использоваться как готовый .env.

NEO4J_USER=neo4j
NEO4J_PASSWORD=<set_manually>
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_DATABASE=neo4j
# IMPORTANT: shadow-mode only, no runtime decision path integration.
KV_SHADOW_MODE=true
KV_DUAL_WRITE_ENABLED=true
KV_READ_ANALYTICS_ENABLED=true
